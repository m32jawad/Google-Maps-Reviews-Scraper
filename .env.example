# Copy to .env next to docker-compose.yml and fill in.

# Auth token clients must send (Authorization: Bearer <token> or ?token=).
# Generate one:  openssl rand -hex 32
API_TOKEN=

# Postgres password for the bundled db service.
POSTGRES_PASSWORD=

# How many scrape workers may run at the same time.
MAX_CONCURRENT_WORKERS=4

# RAM per worker container (request may override memory_mb up to the max).
DEFAULT_MEMORY_MB=512
MAX_MEMORY_MB=2048

# CPU share per worker container.
WORKER_CPUS=1.0

# Kill a run after this many seconds (request may override up to 6h).
DEFAULT_TIMEOUT_SECS=3600

# Rotating proxy pool used by every run that doesn't send its own "proxies".
# Comma-separated, e.g. your Webshare rotating endpoint.
# DEFAULT_PROXY_URLS=http://user:pass@p.webshare.io:80
DEFAULT_PROXY_URLS=

# Host port the API listens on (nginx proxies the domain to this).
API_PORT=9001
